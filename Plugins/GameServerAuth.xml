    <!-- GitHub repository ID -->
    <RepoId>OwendB1/GameServerAuth-MagnetarPlugin</RepoId>

    <!-- The name of your plugin that will appear in the plugin list -->
    <FriendlyName>GameServerAuth</FriendlyName>

    <!-- The author name that you want to appear in the plugin list -->
    <Author>OwendB</Author>

    <!-- Optional tooltip for the plugin in the plugin list -->
    <Tooltip>Discord-backed server access control for Magnetar.</Tooltip>

    <!-- Optional plugin description. If omitted, this will be the same as the Tooltip. 1000 characters max. -->
    <Description>GameServerAuth connects Space Engineers dedicated servers to the Game Server Auth service. Players link Discord and Steam accounts, then authorize in-game with chat commands. Server owners can manage role-based join access, promotion levels, reserved slots, and cluster lobby redirects from the web control plane.</Description>

    <!-- Only source code in the Directory entries listed in SourceDirectories is compiled. Exclude any test projects or similar. -->
